# App
DEBUG=false
SECRET_KEY=cambia-esto-en-produccion-min-32-chars

# Database (SQLite — no necesita servidor externo)
DATABASE_URL=sqlite+aiosqlite:///./audiomedia.db

# LLM (OpenAI)
OPENAI_API_KEY=sk-...

# Modelo para ahorrar tokens 
LLM_MODEL=gpt-4o-mini

# Optimización para PDFs grandes
LLM_USE_SUMMARIZATION=true
LLM_SUMMARIZE_THRESHOLD_CHARS=50000
LLM_SUMMARIZE_CHUNK_SIZE=2000
LLM_SUMMARIZE_MAX_TOKENS=300
LLM_MAX_TOKENS=400


# Upload
UPLOAD_DIR=/tmp/audiomedia/uploads
MAX_UPLOAD_SIZE_MB=50

# CORS
ALLOWED_ORIGINS=["http://localhost:5173","http://localhost:3000"]
